{
  "rewrites": [
    { "source": "/comercio", "destination": "/comercio/index.html" },
    { "source": "/carga/:slug", "destination": "/comercio/carga-venta.html" }
    { "source": "/chat/:slug", "destination": "/comercio/chat.html" }
  ],
  "headers": [
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
